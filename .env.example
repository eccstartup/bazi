# 支付宝配置
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=./certs/app_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=./certs/alipay_public_key.pem
ALIPAY_NOTIFY_URL=http://your-domain.com/alipay/notify
ALIPAY_RETURN_URL=http://your-domain.com/alipay/return

# 服务配置
PORT=3000
SESSION_SECRET=change-this-to-a-random-string
